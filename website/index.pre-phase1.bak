<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SecureTheCloud — Deterministic Governance Infrastructure</title>
  <meta name="description" content="Deterministic Zero-Trust Runtime for AI Systems. Issue. Validate. Revoke. Prove." />
  <link rel="stylesheet" href="/assets/css/stc.css" />
</head>

<body>

  <div class="bg-grid"></div>

  <!-- ========================================================= -->
  <!-- TOP BAR -->
  <!-- ========================================================= -->
  <header class="topbar">
    <div class="container topbar__inner">

      <a href="/" class="brand">
        <div class="brand__mark">STC</div>
        <div class="brand__name">SecureTheCloud</div>
      </a>

      <nav class="nav">
        <a href="/architecture">Architecture</a>
        <a href="/runtime">Runtime</a>
        <a href="/whitepaper">Whitepaper</a>
      </nav>

      <div class="topbar__actions">
        <a href="/shield" class="btn btn--ghost">Shield</a>
        <a href="/copilot" class="btn btn--primary">Access Console</a>
      </div>

    </div>
  </header>

  <!-- ========================================================= -->
  <!-- HERO SECTION (UPDATED) -->
  <!-- ========================================================= -->
  <section class="hero container">

    <div>
      <div class="eyebrow">SecureTheCloud</div>

      <h1>Zero-Trust Runtime for AI Agents</h1>

      <p class="lede">
        Every issued token carries a cryptographic decision_hash of the policy evaluation that authorized it.
        No LLM in the enforcement path.
        Deterministic governance, verifiable at runtime.
      </p>

      <div class="cta">
        <a href="/request-access" class="btn btn--primary">Request Access</a>
        <a href="/architecture" class="btn btn--ghost">View Architecture</a>
      </div>
    </div>

    <div id="stc-enforcement-graph"></div>

  </section>

  <!-- ========================================================= -->
  <!-- ARCHITECTURE SNAPSHOT -->
  <!-- ========================================================= -->
  <section class="section section--divider">
    <div class="container">

      <h2 class="h-section">Three-Plane Architecture</h2>

      <div class="two-up">

        <div class="card">
          <div class="card__k">Decision Plane</div>
          <h2>Intelligence Core</h2>
          <p>
            Deterministic graph traversal (controlplane.v1 / v1.1),
            Continuous Access Enforcement activation,
            version-pinned decision hashes,
            structured revocation propagation.
          </p>
        </div>

        <div class="card">
          <div class="card__k">Enforcement Plane</div>
          <h2>Zero-Trust Runtime</h2>
          <p>
            Redis-backed authority store,
            strict introspection validation,
            immediate session deletion on revocation,
            audit-anchored lifecycle verification.
          </p>
        </div>

      </div>

    </div>
  </section>

  <!-- ========================================================= -->
  <!-- AUTHORITY LIFECYCLE -->
  <!-- ========================================================= -->
  <section class="section section--divider">
    <div class="container">

      <h2 class="h-section">Authority Lifecycle</h2>

      <div class="lifecycle">

        <div class="lifecycle__step">
          <h3>Issue</h3>
          <p>Session authority written to Redis. Audit block appended.</p>
        </div>

        <div class="lifecycle__step">
          <h3>Introspect</h3>
          <p>JWT signature verified. Redis authority validated.</p>
        </div>

        <div class="lifecycle__step">
          <h3>Revoke</h3>
          <p>Session deleted immediately. Enforcement guaranteed.</p>
        </div>

        <div class="lifecycle__step">
          <h3>Verify</h3>
          <p>Hash chain validated for forensic continuity.</p>
        </div>

      </div>

    </div>
  </section>

  <!-- ========================================================= -->
  <!-- ENTERPRISE POSITIONING -->
  <!-- ========================================================= -->
  <section class="section section--divider">
    <div class="container container--narrow">

      <h2 class="h-section">Built for Regulated Environments</h2>

      <p class="lede">
        SecureTheCloud produces audit-ready governance evidence.
        Designed for AI platform teams, security architects,
        and enterprises requiring deterministic authority enforcement.
      </p>

      <div class="proof-strip">
        <div class="proof-row">
          <div>SOC 2 logical isolation alignment</div>
          <div>Replay-verifiable lifecycle evidence</div>
          <div>Version-pinned governance records</div>
          <div>No LLM in enforcement path</div>
        </div>
      </div>

    </div>
  </section>

  <!-- ========================================================= -->
  <!-- FOOTER -->
  <!-- ========================================================= -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="small muted">
        SecureTheCloud v1.0 — Deterministic Edition
      </div>
      <div class="small muted">
        Multi-Tenant Isolation — Phase 5
      </div>
    </div>
  </footer>

  <script src="/assets/js/api-client.js"></script>
  <script src="/assets/js/enforcement-graph.js"></script>
  <script src="/assets/js/stc-home.js"></script>

</body>
</html>
